PORT=3001
NODE_ENV=development

# Express backend base URL (no trailing slash, no /api suffix)
ENS_BACKEND_URL=https://ensapi.ensbot.net

# Public host used to rewrite /uploads/* URLs in responses
ASSET_PUBLIC_BASE_URL=https://ensapi.ensbot.net

# Comma-separated origins, or * for development
CORS_ORIGINS=*

# Required: same value as backend SECRET_KEY / ENCRYPTION_KEY (x-api-key for /api/* upstream)
SECRET_KEY=

# Optional: local JWT validation (same secret as Express backend)
# JWT_ACCESS_SECRET=

# Public menu link suffix for share tab helpers
PUBLIC_MENU_HOST_SUFFIX=.ensmenu.com

# HTTP timeouts (milliseconds)
UPSTREAM_TIMEOUT_MS=30000
IMPORT_TIMEOUT_MS=90000
UPLOAD_MAX_MB=10

# Optional: Pexels image search (server-side only — never expose to Flutter)
# PEXELS_API_KEY=

# AI menu import — N8N webhook (terminate analyze at gateway; same as ens-menu-main)
N8N_MENU_IMPORT_WEBHOOK=https://ensbot.net/webhook/menu-import
