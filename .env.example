PORT=3001
NODE_ENV=development

# Express backend base URL (no trailing slash, no /api suffix)
ENS_BACKEND_URL=https://ensapi.ensbot.net

# Public host used to rewrite /uploads/* URLs in responses
ASSET_PUBLIC_BASE_URL=https://ensapi.ensbot.net

# Comma-separated origins. Use * only in development.
# Production MUST set an explicit allowlist (wildcard is rejected at startup).
CORS_ORIGINS=*

# Required: same value as Express SECRET_KEY / ENCRYPTION_KEY (x-api-key for /api/* upstream).
# Minimum 32 characters (must match Express).
SECRET_KEY=

# Required for JWT verification on protected routes.
# MUST match Express JWT_ACCESS_SECRET (min 32 chars). Never use JWT_REFRESH_SECRET here.
# Required in production (validated at startup).
JWT_ACCESS_SECRET=

# Reverse-proxy hops trusted for client IP / rate limiting (0 = trust none).
# MUST equal the number of proxies that append X-Forwarded-For in front of this process.
# Too high → clients can spoof IP and bypass throttling. Too low → wrong client IP.
# Allowed range: 0–5. Production default when unset is 1. Set explicitly for your LB.
# Example: one nginx/ALB hop → TRUST_PROXY_HOPS=1
# TRUST_PROXY_HOPS=1

# Request body limits (Express JSON / urlencoded)
# REQUEST_JSON_LIMIT=1mb
# REQUEST_URLENCODED_LIMIT=1mb

# Upstream axios max request/response body size (bytes)
# UPSTREAM_MAX_CONTENT_LENGTH_BYTES=15728640

# Seconds added to x-api-key timestamp when local clock lags ensapi (fixes 405 Token expired)
# API_KEY_TIME_OFFSET_SECONDS=30

# Log Express upstream status + error summary in gateway terminal (default: on in development)
# Never logs Authorization headers or full response bodies.
# UPSTREAM_DEBUG_LOG=true

# Public menu link suffix for share tab helpers
PUBLIC_MENU_HOST_SUFFIX=.ensmenu.com

# HTTP timeouts (milliseconds)
UPSTREAM_TIMEOUT_MS=30000
IMPORT_TIMEOUT_MS=90000
UPLOAD_MAX_MB=10

# Owner Android app version check (public GET /mobile/v1/app/version — no DB)
# APP_ANDROID_LATEST_VERSION=1.0.1
# APP_ANDROID_MINIMUM_VERSION=1.0.0
# APP_ANDROID_FORCE_UPDATE=false
# APP_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=com.ensmenu.ens_owner_app
# APP_ANDROID_RELEASE_NOTES=["Bug fixes","Performance improvements"]
# THROTTLE_APP_VERSION_TTL_MS=60000
# THROTTLE_APP_VERSION_LIMIT=30

# Rate limiting (HTTP 429 when exceeded)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=20
THROTTLE_SENSITIVE_TTL_MS=60000
THROTTLE_SENSITIVE_LIMIT=40
THROTTLE_MAPS_TTL_MS=60000
THROTTLE_MAPS_LIMIT=30
THROTTLE_MAPS_OWNER_TTL_MS=60000
THROTTLE_MAPS_OWNER_LIMIT=30
# THROTTLE_HEALTH_TTL_MS=60000
# THROTTLE_HEALTH_LIMIT=60
# THROTTLE_INTERNAL_NOTIFICATIONS_TTL_MS=60000
# THROTTLE_INTERNAL_NOTIFICATIONS_LIMIT=60

# Optional: Pexels image search (server-side only — never expose to Flutter)
# PEXELS_API_KEY=

# Google Places + Geocoding web-service key (server-only — never expose to Flutter)
# Use a dedicated key restricted by IP / API (Places + Geocoding). Do NOT reuse
# Maps SDK Android/iOS keys or Firebase client keys.
# GOOGLE_MAPS_SERVER_API_KEY=
# MAPS_UPSTREAM_TIMEOUT_MS=8000

# AI menu import — N8N webhook (required to enable analyze; no hardcoded fallback)
# N8N_MENU_IMPORT_WEBHOOK=

# Firebase push notifications — use ONE of:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/outside/repo/service-account.json

# Internal notifications endpoint (backend → gateway)
# Required in production (min 32 characters). Compared with constant-time equality.
# INTERNAL_NOTIFICATIONS_SECRET=

# Device token store path (default: ./data/notification-devices.json)
# NOTIFICATION_DEVICES_STORE_PATH=./data/notification-devices.json
